# ─────────────────────────────────────────
# Fase 0 — apenas estas variáveis são necessárias
# ─────────────────────────────────────────
SECRET_KEY=django-insecure-dev-only
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────
# Fase A — serviços externos (PostgreSQL, Redis, MinIO, IA, YouTube)
# ─────────────────────────────────────────

# Database
DATABASE_URL=postgresql://studio:studio@localhost:5451/studio

# Redis — broker Celery + channel layer (slot 18: 6380+18=6398)
REDIS_URL=redis://localhost:6398/0

# MinIO (slot 18: API 9018, console 9019)
MINIO_ENDPOINT=localhost:9018
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=studio
MINIO_USE_SSL=False

# IA
ANTHROPIC_API_KEY=sk-ant-xxx

# Google / YouTube OAuth 2.0
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
OAUTH_REDIRECT_URI=http://localhost:3018/api/oauth/youtube/callback/
OAUTH_ENCRYPTION_KEY=<gere-com-openssl-rand-hex-32>

# Dev
PORT=3018
